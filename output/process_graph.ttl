@prefix ex: <http://example.org/process-kg/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ex:Decision a rdfs:Class .

ex:Process a rdfs:Class .

ex:Role a rdfs:Class .

ex:System a rdfs:Class .

ex:Task a rdfs:Class .

ex:condition a rdf:Property .

ex:falseNext a rdf:Property .

ex:hasDecision a rdf:Property .

ex:hasTask a rdf:Property .

ex:manager a ex:Role ;
    rdfs:label "Manager" .

ex:performedBy a rdf:Property .

ex:precedes a rdf:Property .

ex:purchase_request a ex:Process ;
    rdfs:label "Purchase Request Approval" ;
    ex:hasDecision ex:decision_1 ;
    ex:hasTask ex:task_1,
        ex:task_3,
        ex:task_4 .

ex:trueNext a rdf:Property .

ex:usesSystem a rdf:Property .

ex:decision_1 a ex:Decision ;
    rdfs:label "Check request value" ;
    ex:condition "Request value exceeds approval threshold" ;
    ex:falseNext ex:task_4 ;
    ex:trueNext ex:task_3 .

ex:erp a ex:System ;
    rdfs:label "ERP System" .

ex:purchaser a ex:Role ;
    rdfs:label "Purchaser" .

ex:task_1 a ex:Task ;
    rdfs:label "Submit purchase request" ;
    ex:performedBy ex:purchaser ;
    ex:precedes ex:task_2 .

ex:finance a ex:Role ;
    rdfs:label "Finance" .

ex:task_3 a ex:Task ;
    rdfs:label "Review high-value request" ;
    ex:performedBy ex:finance ;
    ex:precedes ex:task_4 .

ex:task_4 a ex:Task ;
    rdfs:label "Create purchase order" ;
    ex:performedBy ex:finance ;
    ex:usesSystem ex:erp .

